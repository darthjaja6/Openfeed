# Copy this file to the instance root as `.env.local`.
# The instance runner sources it before each openfeed command.

OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

TICLAWK_API_URL=https://ticlawk.com
TICLAWK_PUBLISHER_API_KEY=tk_REPLACE_ME

# Keep these set while validating config. Remove them or set to 0 when you are
# ready to push cards and collect feedback from Ticlawk.
OPENFEED_DISABLE_PUSH=1
OPENFEED_DISABLE_FEEDBACK=1
OPENFEED_DISABLE_LEARN=1

# Cron/browser environment. Adjust if Chrome is attached to another display.
DISPLAY=:10.0
OPENFEED_PATH_PREFIX=/home/YOUR_USER/.local/bin:/usr/local/bin:/usr/bin:/bin
